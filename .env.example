# ─────────────────────────────────────────────────────────────────────────────
# VivaEventos - Variables de entorno
# Copiar este archivo como .env y completar los valores reales.
# NUNCA subir el .env al repositorio (R-11: no exponer secretos).
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_USER=vivaeventos
DB_PASSWORD=change_me_in_production

# ── Nombres de bases de datos ─────────────────────────────────────────────────
DB_EVENTS_NAME=eventdb
DB_ORDERS_NAME=orderdb
DB_PAYMENTS_NAME=paymentdb
DB_TICKETS_NAME=ticketdb
DB_NOTIFICATIONS_NAME=notificationdb

# ── Eureka (registro de servicios) ────────────────────────────────────────────
# URL interna que usan los microservicios para registrarse en Eureka.
# El nombre "vivaeventos-discovery-server" es el container_name del compose.
EUREKA_URL=http://vivaeventos-discovery-server:8761/eureka

# ── Seguridad / JWT ───────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 64
JWT_SECRET=change_me_with_a_secure_random_secret_at_least_256_bits

# ── Pasarela de pagos (Wompi sandbox - R-04) ─────────────────────────────────
# Obtener en: https://comercios.wompi.co
PAYMENT_GATEWAY_URL=https://sandbox.wompi.co/v1
PAYMENT_PUBLIC_KEY=pub_test_XXXXXXXXXXXXXXXXXXXXXXXX
PAYMENT_PRIVATE_KEY=prv_test_XXXXXXXXXXXXXXXXXXXXXXXX
PAYMENT_WEBHOOK_SECRET=change_me_webhook_secret

# ── Notificaciones / Email ────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@vivaeventos.com
MAIL_PASSWORD=change_me_app_password